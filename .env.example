# Copy this file to ".env" and fill in real values before running the server.
# NEVER commit your real .env file to git or share it publicly.

# Port the server listens on
PORT=4000

# Long random secret used to sign login sessions (JWT).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# How long a login session stays valid
JWT_EXPIRES_IN=12h

# Set to "production" when deployed live (enables secure cookies, requires HTTPS)
NODE_ENV=development

# Comma-separated list of frontend origins allowed to call this API
# (only needed if you host the frontend separately from this server)
CORS_ORIGINS=http://localhost:4000

# Where the database file and uploaded images are stored.
# Leave this BLANK for local development (it defaults to this project folder).
# On Render (or any host that only allows ONE persistent disk per service),
# set this to your disk's mount path, e.g.:  DATA_DIR=/var/data
DATA_DIR=

# ---- Google Login (optional) ----
# Get these from Google Cloud Console > APIs & Services > Credentials
# Create an "OAuth 2.0 Client ID" (type: Web application).
# Authorized redirect URI must exactly match GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# ---- Facebook Login (optional) ----
# Get these from developers.facebook.com > My Apps > (create app) > Settings > Basic
# Under Facebook Login product settings, add FACEBOOK_REDIRECT_URI as a Valid OAuth Redirect URI.
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:4000/api/auth/facebook/callback

# ---- Email Verification (required for new user signups to work in production) ----
# Without these, new signups will still work but the verification code will
# only appear in the server console/API response ("dev mode") instead of a
# real email — fine for testing, NOT fine for real users.
#
# Easiest option: Gmail with an "App Password" (not your regular password):
#   1. Turn on 2-Step Verification on your Google Account
#   2. Go to https://myaccount.google.com/apppasswords and create one for "Mail"
#   3. Use that 16-character password below (EMAIL_SMTP_PASS)
# Any other SMTP provider (Zoho, Outlook, SendGrid SMTP, etc.) works too —
# just use their host/port/credentials instead.
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=your-email@gmail.com
EMAIL_SMTP_PASS=your-16-char-app-password
EMAIL_FROM=E-Codex Play <your-email@gmail.com>
